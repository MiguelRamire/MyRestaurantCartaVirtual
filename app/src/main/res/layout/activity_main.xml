<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Space
            android:layout_width="match_parent"
            android:layout_height="51dp" />

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="match_parent"
            android:layout_height="371dp"
            app:srcCompat="@drawable/myrestaurant" />

        <Button
            android:id="@+id/buttonReservar"
            android:layout_width="match_parent"
            android:layout_height="68dip"
            android:onClick="realizarReserva"
            android:text="@string/reservas"
            android:textSize="16sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <Button
            android:id="@+id/buttonSedes"
            android:layout_width="match_parent"
            android:layout_height="68dip"
            android:onClick="consultarSedes"
            android:text="@string/sedes"
            android:textSize="16sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="26dp" />

        <Button
            android:id="@+id/buttonMenú"
            android:layout_width="match_parent"
            android:layout_height="68dip"
            android:onClick="verMenu"
            android:text="@string/menú"
            android:textSize="16sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>